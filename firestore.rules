rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return true; } // allow all for now to enable guest checkout
    
    // Admins helper (if needed)
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }

    // Validation Helpers
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'image', 'category']) &&
        data.name is string && data.name.size() <= 150 &&
        data.price is number &&
        data.image is string && data.image.size() <= 1024 &&
        data.category is string && data.category.size() <= 50;
    }

    function isValidOrder(data) {
      return true;
/*
      return data.keys().hasAll(['userId', 'items', 'total', 'status', 'createdAt']) &&
        data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid &&
        data.items is list && data.items.size() <= 100 &&
        data.total is number &&
        data.status is string && data.status.size() <= 50 &&
        data.createdAt == request.time;
    }*/
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt', 'isAdmin']) &&
        data.email is string && data.email.size() <= 255 &&
        data.isAdmin is bool &&
        data.createdAt == request.time;
    }

    function isValidCartItem(data) {
      return data.keys().hasAll(['productId', 'quantity', 'addedAt']) &&
        data.productId is string && data.productId.size() <= 128 &&
        data.quantity is number &&
        data.addedAt == request.time;
    }

    function isValidWishlistItem(data) {
      return data.keys().hasAll(['productId', 'addedAt']) &&
        data.productId is string && data.productId.size() <= 128 &&
        data.addedAt == request.time;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['productId', 'userId', 'rating', 'createdAt']) &&
        data.productId is string && data.productId.size() <= 128 &&
        data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid &&
        data.rating is number &&
        data.createdAt == request.time;
    }

    // Products
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow delete: if isAdmin() && isValidId(productId);
    }

    // Orders
    match /orders/{orderId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(orderId) && existing().userId == request.auth.uid;
      allow create: if true; // allow anyone to create order
      allow update: if isAdmin() && isValidId(orderId) && isValidOrder(incoming()); // Only admin can update order status
      allow delete: if isAdmin() && isValidId(orderId);
    }

    // Users
    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && userId == request.auth.uid;
      allow create: if isVerified() && isValidId(userId) && userId == request.auth.uid && isValidUser(incoming());
      // No updates for now or strict key constraints if we allow display name updates
      allow update: if isVerified() && isValidId(userId) && userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']) &&
        (!('displayName' in incoming()) || (incoming().displayName is string && incoming().displayName.size() <= 150)) &&
        (!('photoURL' in incoming()) || (incoming().photoURL is string && incoming().photoURL.size() <= 1024));
      
      // User Cart
      match /cart/{cartItemId} {
        allow list: if isSignedIn() && isValidId(userId) && userId == request.auth.uid;
        allow get: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && isValidId(cartItemId);
        allow create: if isVerified() && isValidId(userId) && userId == request.auth.uid && isValidId(cartItemId) && isValidCartItem(incoming());
        allow update: if isVerified() && isValidId(userId) && userId == request.auth.uid && isValidId(cartItemId) && 
          incoming().diff(existing()).affectedKeys().hasOnly(['quantity', 'addedAt']) &&
          incoming().quantity is number &&
          incoming().addedAt == request.time;
        allow delete: if isVerified() && isValidId(userId) && userId == request.auth.uid && isValidId(cartItemId);
      }

      // User Wishlist
      match /wishlist/{wishlistItemId} {
        allow list: if isSignedIn() && isValidId(userId) && userId == request.auth.uid;
        allow get: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && isValidId(wishlistItemId);
        allow create: if isVerified() && isValidId(userId) && userId == request.auth.uid && isValidId(wishlistItemId) && isValidWishlistItem(incoming());
        allow delete: if isVerified() && isValidId(userId) && userId == request.auth.uid && isValidId(wishlistItemId);
      }
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isVerified() && isValidId(reviewId) && isValidReview(incoming());
      allow update: if false; // Reviews are immutable
      allow delete: if isVerified() && isValidId(reviewId) && existing().userId == request.auth.uid;
    }
  }
}
